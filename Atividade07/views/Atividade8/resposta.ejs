<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Delius&family=Pacifico&display=swap" rel="stylesheet">
    <title>Status do Login</title>
    <style>
        body {
      margin: 0;
      padding: 0;
      font-family: 'Delius', cursive;
      font-size: 16px;
      line-height: 1.6;
      color: #5D5D5D;
      background-color: #FFF9FB;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .response-card {
      background: white;
      padding: 40px 30px;
      border-radius: 35px;
      box-shadow: 0 10px 25px rgba(242, 68, 114, 0.15);
      border: 3px solid #A2CDF2;
      text-align: center;
      max-width: 400px;
      width: 100%;
    }

    h1 {
      font-family: 'Pacifico', cursive;
      margin-bottom: 20px;
      font-size: 2.2em;
    }

    /* Cor dinâmica via EJS inline */
    .status-box {
      padding: 20px;
      border-radius: 25px;
      margin: 20px 0;
      background-color: <%= status === 'sucesso' ? '#d4edda' : '#f8d7da' %>;
      color: <%= status === 'sucesso' ? '#155724' : '#721c24' %>;
      border: 1px solid <%= status === 'sucesso' ? '#c3e6cb' : '#f5c6cb' %>;
    }

    .btn-group {
      margin-top: 25px;
    }

    .btn-link {
      display: inline-block;
      text-decoration: none;
      font-family: 'Delius', cursive;
      font-weight: 700;
      border: 2px solid #F24472;
      color: #F24472;
      background: white;
      padding: 10px 20px;
      border-radius: 50px;
      margin: 5px 10px;
      transition: all 0.3s ease;
    }

    .btn-link:hover {
      background-color: #F24472;
      color: white;
      transform: translateY(-3px);
      box-shadow: 0 4px 8px rgba(242, 68, 114, 0.25);
    }

    .username {
      font-weight: bold;
      color: #F24472;
    }
    </style>
</head>
<body>
  <div class="response-card">
    <div class="status-box">
      <h1><%= status === 'sucesso' ? '🎉 Sucesso!' : '❌ Ops!' %></h1>
      <p style="font-size: 1.2em;"><%= mensagem %></p>
      <% if (status === 'sucesso') { %>
        <p>Bem-vindo(a), <span class="username"><%= usuario %></span>!</p>
      <% } %>
    </div>
    <div class="btn-group">
      <a href="/lab08/Login" class="btn-link">Tentar novamente</a>
      <a href="/lab08/Cadastro" class="btn-link">Fazer cadastro</a>
      <a href="/Atividade02/Projects.html" class="btn-link">Ver Projetos</a>
    </div>
  </div>
</body>
</html>