<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Login do Sistema de Carros</title>
  <link rel="stylesheet" href="./../Atividade10/css/style.css">
</head>
<body>
  <div class="form-card">
    <h2>Login</h2>
    <% if (erro) { %><p class="erro"><%= erro %></p><% } %>
    <form action="/lab10/usuarios/login" method="POST">
      <input type="text" name="login" placeholder="Login" required>
      <input type="password" name="senha" placeholder="Senha" required>
      <button type="submit" class="btn">Entrar</button>
    </form>
    <div class="link">Não tem conta? <a href="/lab10/usuarios/cadastro">Cadastre-se</a></div>
  </div>
</body>
</html>